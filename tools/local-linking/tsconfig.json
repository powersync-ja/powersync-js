{
  "compilerOptions": {
    "target": "ES2020",
    "module": "nodenext",
    "types": ["node"],
    "lib": ["ES2020"],
    "moduleResolution": "nodenext",
    "outDir": "dist",
    "rootDir": "src",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "declaration": false,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"]
}
