{
  "name": "powersync-js",
  "version": "1.0.0",
  "private": true,
  "description": "monorepo for powersync javascript sdks",
  "main": "index.js",
  "scripts": {
    "build:packages": "pnpm run --filter {./packages/**} -r build",
    "build:packages:prod": "pnpm run --filter {./packages/**} -r build:prod",
    "clean:packages": "pnpm run --filter {./packages/**} -r clean",
    "watch:packages": "pnpm run --parallel --filter {./packages/**} -r build -w",
    "changeset:version": "pnpm changeset version && pnpm install --lockfile-only --frozen-lockfile=false",
    "build": "pnpm run -r build",
    "ci:publish": "changeset publish && git push --follow-tags",
    "ci:version": "changeset version && pnpm install --no-frozen-lockfile",
    "clean": "pnpm run -r clean",
    "docs:build": "pnpm --filter docs build",
    "docs:start": "pnpm --filter docs start",
    "docs:clear": "pnpm --filter docs clear",
    "format": "prettier --write .",
    "lint": "eslint .",
    "release": "pnpm build:packages:prod && pnpm changeset publish",
    "test": "pnpm run -r --workspace-concurrency=1 test --run",
    "test:packages:exports": "pnpm -r --filter {./packages/**} test:exports"
  },
  "keywords": [],
  "type": "module",
  "author": "JOURNEYAPPS",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.9.0"
  },
  "devDependencies": {
    "@actions/core": "catalog:",
    "@arethetypeswrong/cli": "catalog:",
    "@changesets/cli": "catalog:",
    "@pnpm/workspace.find-packages": "catalog:",
    "@rollup/plugin-commonjs": "catalog:",
    "@rollup/plugin-node-resolve": "catalog:",
    "@rollup/plugin-typescript": "catalog:",
    "@vitest/browser": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "playwright": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-embed": "catalog:",
    "prettier-plugin-sql": "catalog:",
    "rollup": "catalog:",
    "rollup-plugin-dts": "catalog:",
    "typescript": "catalog:",
    "tsx": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.21.0+sha512.da3337267e400fdd3d479a6c68079ac6db01d8ca4f67572083e722775a796788a7a9956613749e000fac20d424b594f7a791a5f4e2e13581c5ef947f26968a40"
}
