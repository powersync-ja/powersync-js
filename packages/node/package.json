{
  "name": "@powersync/node",
  "version": "0.18.7",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "description": "PowerSync Node.js SDK",
  "main": "lib/index.js",
  "files": [
    "lib",
    "dist",
    "download_core.js",
    "src"
  ],
  "scripts": {
    "prepare:core": "node download_core.js",
    "build": " pnpm prepare:core && tsc -b",
    "build:prod": "pnpm prepare:core && tsc -b",
    "clean": "rm -rf lib dist tsconfig.tsbuildinfo",
    "watch": "tsc -b -w",
    "test": " pnpm prepare:core && vitest",
    "test:exports": "attw --pack . --ignore-rules no-resolution cjs-resolves-to-esm"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "module-sync": "./lib/index.js"
    },
    "./worker.js": {
      "types": "./lib/worker.d.ts",
      "module-sync": "./lib/worker.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/powersync-ja/powersync-js.git"
  },
  "author": "PowerSync",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/powersync-ja/powersync-js/issues"
  },
  "homepage": "https://docs.powersync.com/",
  "peerDependencies": {
    "@powersync/common": "workspace:^1.53.2",
    "better-sqlite3": "12.x"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    }
  },
  "dependencies": {
    "@powersync/common": "workspace:*",
    "comlink": "catalog:",
    "undici": "^7.11.0"
  },
  "devDependencies": {
    "@powersync/drizzle-driver": "workspace:*",
    "@types/node": "catalog:",
    "better-sqlite3": "^12.10.0",
    "@types/better-sqlite3": "^7.6.13",
    "bson": "catalog:",
    "drizzle-orm": "catalog:",
    "js-logger": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "keywords": [
    "data sync",
    "offline-first",
    "sqlite",
    "real-time data stream",
    "live data"
  ]
}