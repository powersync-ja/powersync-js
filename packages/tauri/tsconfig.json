{
  "extends": "../../tsconfig.base",
  "compilerOptions": {
    "baseUrl": "./",
    "target": "esnext",
    "module": "esnext",
    "rootDir": "guest-js",
    "outDir": "./lib",
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noImplicitAny": true
  },
  "include": ["guest-js/"],
