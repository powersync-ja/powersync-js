{
  "name": "@powersync/drizzle-driver",
  "version": "0.7.4",
  "description": "Drizzle driver for PowerSync",
  "type": "module",
  "main": "lib/src/index.js",
  "module": "lib/src/index.js",
  "types": "lib/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/src/index.d.ts",
      "default": "./lib/src/index.js"
    }
  },
  "author": "PowerSync",
  "license": "Apache-2.0",
  "files": [
    "lib",
    "src"
  ],
  "repository": "https://github.com/powersync-ja/powersync-js",
  "bugs": {
    "url": "https://github.com/powersync-ja/powersync-js/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "homepage": "https://docs.powersync.com",
  "scripts": {
    "build": "tsc -b",
    "build:prod": "tsc -b",
    "clean": "rm -rf lib dist tsconfig.tsbuildinfo",
    "watch": "tsc --build -w",
    "test": "vitest",
    "test:exports": "attw --pack . --ignore-rules cjs-resolves-to-esm"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "peerDependencies": {
    "@powersync/common": "workspace:^1.57.0",
    "drizzle-orm": "<1.0.0"
  },
  "devDependencies": {
    "@journeyapps/wa-sqlite": "catalog:",
    "@powersync/web": "workspace:*",
    "@types/node": "catalog:",
    "drizzle-orm": "catalog:",
    "vite": "catalog:"
  }
}
