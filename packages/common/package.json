{
  "name": "@powersync/common",
  "version": "1.54.0",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "description": "API definitions for PowerSync",
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    }
  },
  "author": "PowerSync",
  "license": "Apache-2.0",
  "files": [
    "lib",
    "dist",
    "src",
    "legacy"
  ],
