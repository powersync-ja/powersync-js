# Copy this template: `cp .env.template .env.local`
# Edit .env.local and enter your project details.

# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=anonymous:anonymous-agent

# Convex HTTP actions URL (self-hosted default: http://127.0.0.1:3211)
VITE_CONVEX_SITE_URL=http://127.0.0.1:3211

# Convex backend URL (for auth, self-hosted default: http://127.0.0.1:3210)
VITE_CONVEX_URL=http://127.0.0.1:3210

# PowerSync service URL
VITE_POWERSYNC_URL=http://localhost:8080
