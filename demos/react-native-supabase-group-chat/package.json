{
  "name": "react-native-supabase-group-chat",
  "version": "1.2.0",
  "main": "expo-router/entry",
  "scripts": {
    "clear": "find ./ -type d -and \\( -name node_modules -or -name build -or -name dist \\) -exec rm -rf '{}' +",
    "ncu": "pnpx npm-check-updates",
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web --clear",
    "doc": "pnpx expo-doctor@latest",
    "prebuild": "expo prebuild --platform ios --clean --no-install",
    "build:simulator": "pnpx eas-cli build --profile simulator --platform ios --local",
    "build:development": "pnpx eas-cli build --profile development --platform ios --local",
    "build:production": "pnpx eas-cli build --profile production --platform ios --local",
    "update:production": "pnpx eas-cli update --non-interactive -p ios --branch=production --auto",
    "types": "supabase gen types typescript --local > src/library/database.types.ts",
    "local:up": "supabase start && docker compose --env-file .env.powersync up -d",
    "local:down": "docker compose --env-file .env.powersync down -v && supabase stop",
    "lint": "eslint src"
  },
  "dependencies": {
    "@azure/core-asynciterator-polyfill": "^1.0.2",
    "@expo/vector-icons": "^15.0.3",
    "@faker-js/faker": "^10.1.0",
    "@op-engineering/op-sqlite": "^17.0.0",
    "@powersync/react-native": "^1.35.6",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@shopify/flash-list": "2.0.2",
    "@supabase/supabase-js": "^2.86.0",
    "@tamagui/babel-plugin": "^1.138.6",
    "@tamagui/core": "^1.138.6",
    "@tamagui/font-inter": "^1.138.6",
    "@tamagui/lucide-icons": "^1.138.6",
    "@tamagui/shorthands": "^1.138.6",
    "@tamagui/themes": "^1.138.6",
    "date-fns": "^4.1.0",
    "expo": "~56.0.12",
    "expo-build-properties": "~56.0.19",
    "expo-constants": "~56.0.18",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.20",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.11",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "tamagui": "^1.138.6"
  },
  "devDependencies": {
    "@babel/plugin-transform-async-generator-functions": "^7.28.0",
    "@types/react": "~19.2.14",
    "dotenv": "^17.2.3",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~56.0.4",
    "typescript": "~6.0.3"
  },
  "license": "UNLICENSED",
  "private": true
}
